# 8004-mcp configuration
#
# Reads work out of the box with built-in defaults.
# Only uncomment or override the values you actually need.

# Network mode: testnet | mainnet
NETWORK_MODE=testnet

# Solana cluster: devnet | mainnet-beta
SOLANA_CLUSTER=devnet

# Optional RPC override for Solana
SOLANA_RPC_URL=

# Optional private keys for write operations
SOLANA_PRIVATE_KEY=
EVM_PRIVATE_KEY=

# Optional indexer overrides
# By default, Solana uses the built-in cluster-aware indexer URL.
INDEXER_URL=
INDEXER_API_KEY=
USE_INDEXER=true
INDEXER_FALLBACK=true
FORCE_ON_CHAIN=false

# Optional IPFS/storage overrides
# Default uploads already use the Studio MCP upload endpoint; override only if needed.
# Optional advanced override: use your own Pinata account instead of the Studio endpoint.
IPFS_UPLOAD_URL=
PINATA_JWT=
IPFS_URL=
FILECOIN_PIN_ENABLED=false
FILECOIN_PRIVATE_KEY=

# Optional crawler timeout override (milliseconds)
MCP_CRAWLER_TIMEOUT_MS=
